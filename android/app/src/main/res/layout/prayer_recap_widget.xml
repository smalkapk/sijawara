<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/prayer_widget_background"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/widgetPrayerLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Menuju Subuh"
        android:textColor="#D1FAE5"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widgetCountdownValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="00j 00m"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:id="@+id/widgetRekapButton"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@drawable/prayer_widget_button_background"
        android:gravity="center"
        android:text="Rekap"
        android:textAllCaps="false"
        android:textColor="#065F46"
        android:textSize="14sp"
        android:textStyle="bold" />

</LinearLayout>